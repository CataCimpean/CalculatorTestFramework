<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <Content Include="TestConfigs\*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon />
    <StartupObject>CalculatorTestFramework.Program</StartupObject>
    <RootNamespace>CalculatorTestFramework</RootNamespace>
    <AssemblyName>CalculatorTestFramework</AssemblyName>
  </PropertyGroup>

</Project>
